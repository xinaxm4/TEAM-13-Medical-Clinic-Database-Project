-- =====================================================
-- Medical Clinic Database Schema
-- Team 13 - Medical Clinic Database Project
-- =====================================================

-- Drop database if exists (for clean setup)
DROP DATABASE IF EXISTS medical_clinic;
CREATE DATABASE medical_clinic;
USE medical_clinic;

-- =====================================================
-- 1. CORE TABLES
-- =====================================================

-- Insurance Providers Table
CREATE TABLE insurance (
    insurance_id INT PRIMARY KEY AUTO_INCREMENT,
    provider_name VARCHAR(100) NOT NULL,
    coverage_percentage DECIMAL(5,2) NOT NULL CHECK (coverage_percentage BETWEEN 0 AND 100),
    contact_phone VARCHAR(20),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Office Locations Table
CREATE TABLE office (
    office_id INT PRIMARY KEY AUTO_INCREMENT,
    street_address VARCHAR(200) NOT NULL,
    city VARCHAR(50) NOT NULL,
    state VARCHAR(2) NOT NULL,
    zip_code VARCHAR(10) NOT NULL,
    phone_number VARCHAR(20),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Appointment Status Lookup Table
CREATE TABLE appointment_status (
    status_id INT PRIMARY KEY AUTO_INCREMENT,
    status_name VARCHAR(20) NOT NULL UNIQUE  -- Scheduled, Completed, Cancelled, No-Show
);

-- Physician Table
CREATE TABLE physician (
    physician_id INT PRIMARY KEY AUTO_INCREMENT,
    first_name VARCHAR(50) NOT NULL,
    last_name VARCHAR(50) NOT NULL,
    specialty VARCHAR(100) NOT NULL,
    license_number VARCHAR(50) UNIQUE NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    phone_number VARCHAR(20),
    is_primary_care BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Patient Table
CREATE TABLE patient (
    patient_id INT PRIMARY KEY AUTO_INCREMENT,
    first_name VARCHAR(50) NOT NULL,
    last_name VARCHAR(50) NOT NULL,
    date_of_birth DATE NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    phone_number VARCHAR(20),
    street_address VARCHAR(200),
    city VARCHAR(50),
    state VARCHAR(2),
    zip_code VARCHAR(10),
    insurance_id INT,
    emergency_contact_name VARCHAR(100),
    emergency_contact_phone VARCHAR(20),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (insurance_id) REFERENCES insurance(insurance_id) ON DELETE SET NULL
);

-- Physician Work Schedule (which office on which day)
CREATE TABLE work_schedule (
    schedule_id INT PRIMARY KEY AUTO_INCREMENT,
    physician_id INT NOT NULL,
    office_id INT NOT NULL,
    weekday ENUM('Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday') NOT NULL,
    start_time TIME NOT NULL,
    end_time TIME NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (physician_id) REFERENCES physician(physician_id) ON DELETE CASCADE,
    FOREIGN KEY (office_id) REFERENCES office(office_id) ON DELETE CASCADE,
    UNIQUE KEY unique_physician_office_day (physician_id, office_id, weekday)
);

-- Patient-Physician Assignment (many-to-many)
CREATE TABLE patient_physician (
    assignment_id INT PRIMARY KEY AUTO_INCREMENT,
    patient_id INT NOT NULL,
    physician_id INT NOT NULL,
    is_primary BOOLEAN DEFAULT FALSE,
    requires_specialist_approval BOOLEAN DEFAULT FALSE,
    approval_status VARCHAR(20) DEFAULT 'Pending', -- Pending, Approved, Denied
    assigned_date DATE DEFAULT (CURDATE()),
    FOREIGN KEY (patient_id) REFERENCES patient(patient_id) ON DELETE CASCADE,
    FOREIGN KEY (physician_id) REFERENCES physician(physician_id) ON DELETE CASCADE,
    UNIQUE KEY unique_patient_physician (patient_id, physician_id)
);

-- Appointments Table
CREATE TABLE appointment (
    appointment_id INT PRIMARY KEY AUTO_INCREMENT,
    patient_id INT NOT NULL,
    physician_id INT NOT NULL,
    office_id INT NOT NULL,
    appointment_date DATE NOT NULL,
    appointment_time TIME NOT NULL,
    duration_minutes INT DEFAULT 30,
    appointment_type ENUM('Physical', 'Specialist', 'Follow-Up', 'General') NOT NULL,
    reason_for_visit TEXT,
    status_id INT DEFAULT 1,  -- 1 = Scheduled
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (patient_id) REFERENCES patient(patient_id) ON DELETE CASCADE,
    FOREIGN KEY (physician_id) REFERENCES physician(physician_id) ON DELETE CASCADE,
    FOREIGN KEY (office_id) REFERENCES office(office_id) ON DELETE CASCADE,
    FOREIGN KEY (status_id) REFERENCES appointment_status(status_id),
    INDEX idx_appointment_date (appointment_date),
    INDEX idx_patient_id (patient_id),
    INDEX idx_physician_id (physician_id)
);

-- Medical History Table
CREATE TABLE medical_history (
    history_id INT PRIMARY KEY AUTO_INCREMENT,
    patient_id INT NOT NULL,
    physician_id INT NOT NULL,
    condition VARCHAR(100) NOT NULL,
    diagnosis_date DATE NOT NULL,
    status VARCHAR(20) DEFAULT 'Active', -- Active, Resolved, Chronic
    notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (patient_id) REFERENCES patient(patient_id) ON DELETE CASCADE,
    FOREIGN KEY (physician_id) REFERENCES physician(physician_id) ON DELETE CASCADE,
    INDEX idx_patient_id (patient_id)
);

-- Billing Table
CREATE TABLE billing (
    bill_id INT PRIMARY KEY AUTO_INCREMENT,
    appointment_id INT NOT NULL,
    patient_id INT NOT NULL,
    insurance_id INT,
    total_amount DECIMAL(10,2) NOT NULL,
    insurance_paid_amount DECIMAL(10,2) DEFAULT 0.00,
    patient_owed DECIMAL(10,2) NOT NULL,
    payment_status ENUM('Unpaid', 'Paid', 'Partial', 'Overdue') DEFAULT 'Unpaid',
    payment_method ENUM('Cash', 'Credit Card', 'Insurance', 'Check') DEFAULT NULL,
    payment_date DATE DEFAULT NULL,
    due_date DATE NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (appointment_id) REFERENCES appointment(appointment_id) ON DELETE CASCADE,
    FOREIGN KEY (patient_id) REFERENCES patient(patient_id) ON DELETE CASCADE,
    FOREIGN KEY (insurance_id) REFERENCES insurance(insurance_id) ON DELETE SET NULL,
    INDEX idx_patient_id (patient_id),
    INDEX idx_payment_status (payment_status)
);

-- =====================================================
-- 2. USER AUTHENTICATION TABLES (for web app)
-- =====================================================

-- Users table for authentication
CREATE TABLE users (
    user_id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(100) UNIQUE NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    role ENUM('patient', 'physician', 'staff') NOT NULL,
    related_id INT,  -- patient_id for patients, physician_id for physicians
    is_active BOOLEAN DEFAULT TRUE,
    last_login TIMESTAMP NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_role (role),
    INDEX idx_related_id (related_id)
);

-- Login attempts tracking for rate limiting
CREATE TABLE login_attempts (
    attempt_id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(100) NOT NULL,
    ip_address VARCHAR(45) NOT NULL,
    attempt_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_username_ip (username, ip_address)
);

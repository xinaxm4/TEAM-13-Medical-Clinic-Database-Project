USE medical_clinic;

-- =====================================================
-- TRIGGER 1: Auto-create Billing when Appointment Completed
-- 
-- Business Rule: When a physician marks an appointment as 'Completed',
-- the system automatically creates a billing record using:
--   - Base cost based on appointment type
--   - Patient's insurance coverage percentage
--   - Calculates insurance paid amount and patient owed
-- =====================================================

DELIMITER $$

DROP TRIGGER IF EXISTS after_appointment_completed$$

CREATE TRIGGER after_appointment_completed
AFTER UPDATE ON appointment
FOR EACH ROW
BEGIN
    DECLARE v_base_cost DECIMAL(10,2);
    DECLARE v_coverage DECIMAL(5,2);
    DECLARE v_insurance_id INT;
    DECLARE v_ins_paid DECIMAL(10,2);
    DECLARE v_patient_owed DECIMAL(10,2);
    
    -- Check if status changed to Completed (status_id = 2)
    IF NEW.status_id = 2 AND OLD.status_id != 2 THEN
        
        -- Check if billing record already exists to prevent duplicates
        IF NOT EXISTS (SELECT 1 FROM billing WHERE appointment_id = NEW.appointment_id) THEN
            
            -- Calculate base cost based on appointment type
            CASE NEW.appointment_type
                WHEN 'Physical' THEN SET v_base_cost = 200.00;
                WHEN 'Specialist' THEN SET v_base_cost = 250.00;
                WHEN 'Follow-Up' THEN SET v_base_cost = 125.00;
                ELSE SET v_base_cost = 150.00;  -- General
            END CASE;
            
            -- Get patient's insurance coverage percentage and insurance_id
            SELECT COALESCE(i.coverage_percentage, 0), p.insurance_id
            INTO v_coverage, v_insurance_id
            FROM patient p
            LEFT JOIN insurance i ON p.insurance_id = i.insurance_id
            WHERE p.patient_id = NEW.patient_id;
            
            -- Calculate insurance paid and patient owed
            SET v_ins_paid = ROUND(v_base_cost * (v_coverage / 100), 2);
            SET v_patient_owed = v_base_cost - v_ins_paid;
            
            -- Insert billing record with due date 30 days from today
            INSERT INTO billing (
                appointment_id,
                patient_id,
                insurance_id,
                total_amount,
                insurance_paid_amount,
                patient_owed,
                payment_status,
                due_date
            ) VALUES (
                NEW.appointment_id,
                NEW.patient_id,
                v_insurance_id,
                v_base_cost,
                v_ins_paid,
                v_patient_owed,
                'Unpaid',
                CURDATE() + INTERVAL 30 DAY
            );
            
        END IF;
    END IF;
END$$

DELIMITER ;

-- =====================================================
-- TRIGGER 2: Log No-Show to Medical History
-- 
-- Business Rule: When an appointment is marked as 'No-Show',
-- the system automatically logs this event in the patient's
-- medical history for tracking and compliance purposes.
-- =====================================================

DELIMITER $$

DROP TRIGGER IF EXISTS after_appointment_noshow$$

CREATE TRIGGER after_appointment_noshow
AFTER UPDATE ON appointment
FOR EACH ROW
BEGIN
    -- Check if status changed to No-Show (status_id = 4)
    IF NEW.status_id = 4 AND OLD.status_id != 4 THEN
        
        -- Check if a no-show record already exists for this appointment
        -- to prevent duplicate entries
        IF NOT EXISTS (
            SELECT 1 FROM medical_history 
            WHERE patient_id = NEW.patient_id 
            AND condition = 'No-Show'
            AND diagnosis_date = NEW.appointment_date
            AND notes LIKE CONCAT('%', NEW.appointment_date, '%')
        ) THEN
            
            -- Insert no-show record into medical history
            INSERT INTO medical_history (
                patient_id,
                physician_id,
                `condition`,
                diagnosis_date,
                status,
                notes
            ) VALUES (
                NEW.patient_id,
                NEW.physician_id,
                'No-Show',
                NEW.appointment_date,
                'Active',
                CONCAT(
                    'Patient did not attend scheduled appointment on ',
                    NEW.appointment_date,
                    ' at ',
                    NEW.appointment_time,
                    '. Reason for visit was: ',
                    IFNULL(NEW.reason_for_visit, 'not specified'),
                    '. Appointment type: ',
                    NEW.appointment_type
                )
            );
            
        END IF;
    END IF;
END$$

DELIMITER ;


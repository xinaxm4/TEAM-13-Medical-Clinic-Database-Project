-- =====================================================
-- OPTIONAL TRIGGER 3: Audit Log for Appointment Status Changes
-- (Bonus - demonstrates additional trigger capability)
-- =====================================================

-- Create audit log table
CREATE TABLE IF NOT EXISTS appointment_audit_log (
    log_id INT PRIMARY KEY AUTO_INCREMENT,
    appointment_id INT NOT NULL,
    old_status_id INT,
    new_status_id INT,
    changed_by VARCHAR(100),
    change_timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_appointment_id (appointment_id)
);

DELIMITER $$

DROP TRIGGER IF EXISTS after_appointment_status_change$$

CREATE TRIGGER after_appointment_status_change
AFTER UPDATE ON appointment
FOR EACH ROW
BEGIN
    -- Log status changes for audit trail
    IF OLD.status_id != NEW.status_id THEN
        INSERT INTO appointment_audit_log (
            appointment_id,
            old_status_id,
            new_status_id,
            changed_by
        ) VALUES (
            NEW.appointment_id,
            OLD.status_id,
            NEW.status_id,
            USER()
        );
    END IF;
END$$

DELIMITER ;

